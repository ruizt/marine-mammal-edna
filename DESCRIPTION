Package: marineedna
Title: Predicting Marine Mammal Density from eDNA
Version: 1.1.0
Authors@R: c(
    person("Trevor D.", "Ruiz", role = c("aut", "cre"),
           comment = c(ORCID = "0009-0001-1452-2542")),
